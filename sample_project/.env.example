# ──────────────────────────────────────────────────────────
# SAP AI Templates — Sample Project Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────

# ── SAP HANA Cloud ─────────────────────────────────────────
HANA_HOST=your-hana-host.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=DBADMIN
HANA_PASSWORD=your-password-here
HANA_CERTIFICATE=

# ── SAP AI Core — Chat LLM ─────────────────────────────────
LLM_DEPLOYMENT_ID=your-chat-llm-deployment-id

# ── SAP AI Core — Embedding Model ──────────────────────────
EMBEDDING_DEPLOYMENT_ID=your-embedding-deployment-id

# ── AI Core local profile ──────────────────────────────────
AICORE_HOME=./profiles
AICORE_PROFILE=default

# ── Vector Store ───────────────────────────────────────────
VECTOR_TABLE_NAME=VECTOR_STORE
