# Copy this file to .env and fill in your values

# ── HANA Credentials (reuse from hana_db_connection) ─────
HANA_HOST=your-host.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=DBADMIN
HANA_PASSWORD=YourPassword
HANA_CERTIFICATE=        # optional

# ── SAP Gen AI Hub — Embedding Model ─────────────────────
# Get from SAP AI Launchpad → AI Core → Deployments
EMBEDDING_DEPLOYMENT_ID=your-embedding-deployment-id

# ── Vector Table Settings ─────────────────────────────────
VECTOR_TABLE_NAME=VECTOR_STORE   # table name in HANA (default: VECTOR_STORE)
VECTOR_DIMENSION=1536            # must match embedding model:
                                 #   text-embedding-ada-002   → 1536
                                 #   text-embedding-3-small   → 1536
                                 #   text-embedding-3-large   → 3072
