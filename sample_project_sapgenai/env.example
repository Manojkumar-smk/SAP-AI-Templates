# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── SAP HANA Cloud ─────────────────────────────────────────
HANA_HOST=your-hana-host.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=DBADMIN
HANA_PASSWORD=your-password-here
HANA_CERTIFICATE=        # optional — leave blank for BTP Trial

# ── SAP Gen AI Hub — LLM ──────────────────────────────────
# Get from: SAP AI Launchpad → AI Core → Deployments
# Deploy a chat model (gpt-4o-mini or gpt-4o) and copy the ID
LLM_DEPLOYMENT_ID=your-chat-llm-deployment-id

# ── SAP Gen AI Hub — Embedding Model ──────────────────────
# Deploy text-embedding-ada-002 and copy the deployment ID
EMBEDDING_DEPLOYMENT_ID=your-embedding-deployment-id

# ── SAP AI Core Profile ────────────────────────────────────
# Path to your AI Core credentials folder
# See: https://help.sap.com/docs/ai-core
AICORE_HOME=~/.aicore
AICORE_PROFILE=default

# ── Vector Store ───────────────────────────────────────────
VECTOR_TABLE_NAME=VECTOR_STORE
