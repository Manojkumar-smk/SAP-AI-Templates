# ──────────────────────────────────────────────────────────
# TEMPLATE 04 — HANA RAG  Environment Variables
# ──────────────────────────────────────────────────────────
# Inherits from Templates 01 and 03.
# Copy this to .env and fill in your values.
# ──────────────────────────────────────────────────────────

# ── From Template 01 (HANA connection) ────────────────────
HANA_HOST=your-hana-host.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=DBADMIN
HANA_PASSWORD=your-password-here
HANA_CERTIFICATE=

# ── SAP AI Core — Embedding model ─────────────────────────
# Must match the model used when vectors were stored (Template 03)
EMBEDDING_DEPLOYMENT_ID=your-embedding-deployment-id

# ── SAP AI Core — Chat/LLM model ──────────────────────────
# Used for generating the final grounded answer
LLM_DEPLOYMENT_ID=your-llm-deployment-id

# ── AI Core profile (local only) ──────────────────────────
AICORE_HOME=./profiles
AICORE_PROFILE=default

# ── Vector table (must match Template 03) ─────────────────
VECTOR_TABLE_NAME=VECTOR_STORE
