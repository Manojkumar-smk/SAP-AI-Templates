# Copy this file to .env and fill in your values
# Used by: llm_setup.py and any file that calls get_llm()

# ── HANA Credentials (reuse from hana_db_connection) ─────
HANA_HOST=your-host.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=DBADMIN
HANA_PASSWORD=YourPassword
HANA_CERTIFICATE=        # optional

# ── SAP Gen AI Hub ────────────────────────────────────────
# Get your deployment ID from SAP AI Launchpad → AI Core → Deployments
LLM_DEPLOYMENT_ID=your-deployment-id-here
