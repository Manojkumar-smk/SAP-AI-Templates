# ──────────────────────────────────────────────────────────
# TEMPLATE 05 — SAP AI Chatbot  Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────

# ── HANA Cloud (from Template 01) ─────────────────────────
HANA_HOST=your-hana-host.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=DBADMIN
HANA_PASSWORD=your-password-here
HANA_CERTIFICATE=

# ── SAP AI Core — Chat LLM ────────────────────────────────
# Used for generating answers
# BTP Cockpit → AI Core → Generative AI Hub → Deployments
LLM_DEPLOYMENT_ID=your-chat-llm-deployment-id

# ── SAP AI Core — Embedding Model ─────────────────────────
# Required only when enable_rag = True
# Must match the model used when storing vectors (Template 03)
EMBEDDING_DEPLOYMENT_ID=your-embedding-deployment-id

# ── AI Core profile (local dev only) ──────────────────────
AICORE_HOME=./profiles
AICORE_PROFILE=default

# ── Vector Table (used when enable_rag = True) ────────────
# Must match the table created by Template 03
VECTOR_TABLE_NAME=VECTOR_STORE
