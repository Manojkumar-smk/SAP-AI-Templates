# ──────────────────────────────────────────────────
# SAP HANA Cloud — Local Environment Variables
# ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────

# HANA Cloud instance hostname
# Example: abc123.hana.trial.eu10.hanacloud.ondemand.com
HANA_HOST=your-hana-host.hanacloud.ondemand.com

# Port — HANA Cloud always uses 443
HANA_PORT=443

# Database user credentials
HANA_USER=DBADMIN
HANA_PASSWORD=your-password-here

# (Optional) SSL certificate — usually not needed for HANA Cloud
# Leave blank if connecting without a custom certificate
HANA_CERTIFICATE=
