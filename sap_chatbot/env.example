# Copy this file to .env and fill in your values

# ── HANA Credentials (reuse from hana_db_connection) ─────
HANA_HOST=your-host.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=DBADMIN
HANA_PASSWORD=YourPassword
HANA_CERTIFICATE=        # optional

# ── SAP Gen AI Hub — Chat LLM ────────────────────────────
# Get from SAP AI Launchpad → AI Core → Deployments (chat model)
LLM_DEPLOYMENT_ID=your-llm-deployment-id

# ── SAP Gen AI Hub — Embedding (only needed for RAG mode) ─
# Get from SAP AI Launchpad → AI Core → Deployments (embedding model)
EMBEDDING_DEPLOYMENT_ID=your-embedding-deployment-id

# ── Vector Store (only needed for RAG mode) ───────────────
VECTOR_TABLE_NAME=VECTOR_STORE
