# ──────────────────────────────────────────────────────────
# TEMPLATE 02 — HANA AI Query Agent  Environment Variables
# ──────────────────────────────────────────────────────────
# Inherits HANA credentials from Template 01.
# Copy this to .env and fill in your values.
# ──────────────────────────────────────────────────────────

# ── From Template 01 (HANA connection) ────────────────────
HANA_HOST=your-hana-host.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=DBADMIN
HANA_PASSWORD=your-password-here
HANA_CERTIFICATE=

# ── SAP AI Core / Gen AI Hub ───────────────────────────────
# Get this from your SAP AI Core deployment (Generative AI Hub)
# BTP Cockpit → AI Core → Deployments → copy the Deployment ID
LLM_DEPLOYMENT_ID=your-deployment-id-here

# ── AI Core profile (for local run only) ──────────────────
# Points to the folder containing your AI Core credentials JSON
# Leave blank when deploying to Cloud Foundry
AICORE_HOME=./profiles
AICORE_PROFILE=default
