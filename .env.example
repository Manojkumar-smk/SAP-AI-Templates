# ──────────────────────────────────────────────────────────
# TEMPLATE 03 — HANA Vector Store  Environment Variables
# ──────────────────────────────────────────────────────────
# Inherits HANA credentials from Template 01.
# Copy this to .env and fill in your values.
# ──────────────────────────────────────────────────────────

# ── From Template 01 (HANA connection) ────────────────────
HANA_HOST=your-hana-host.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=DBADMIN
HANA_PASSWORD=your-password-here
HANA_CERTIFICATE=

# ── SAP AI Core / Gen AI Hub ───────────────────────────────
# Embedding model deployment ID (text-embedding-ada-002)
# BTP Cockpit → AI Core → Deployments → copy the ID
EMBEDDING_DEPLOYMENT_ID=your-embedding-deployment-id-here

# AI Core profile (for local run only)
AICORE_HOME=./profiles
AICORE_PROFILE=default

# ── Vector Table ──────────────────────────────────────────
# Name of the HANA table to store vectors (auto-created)
VECTOR_TABLE_NAME=VECTOR_STORE
